<?xml version="1.0" encoding="utf-8"?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="BRB6.Template.MRDialog"
             IsVisible="{Binding IsMrDialogVisible}">

    <!-- Затемнений фон -->
    <Grid>
        <BoxView Color="Black" Opacity="0.5" />

        <!-- Саме вікно по центру -->
        <Frame CornerRadius="16" BackgroundColor="White" Padding="24"
               HorizontalOptions="Center" VerticalOptions="Center"
               WidthRequest="300" HasShadow="True">
            <VerticalStackLayout Spacing="16">

                <Label Text="Вкажіть актуальну кількість товару"
                       FontSize="18" HorizontalTextAlignment="Center"
                       LineBreakMode="WordWrap" />

                <!-- Лічильник: — кількість + -->
                <Border StrokeShape="RoundRectangle 50" Stroke="#E0E0E0" Padding="10,0">
                    <Grid ColumnDefinitions="Auto,*,Auto" HeightRequest="52">
                        <Button Grid.Column="0" Text="−" FontSize="24" FontAttributes="Bold"
                                TextColor="#333" BackgroundColor="Transparent"  Padding="0"
                                Command="{Binding DecrementCommand}" />
                        <Label Grid.Column="1" Text="{Binding MrQuantity}"
                               FontSize="24" FontAttributes="Bold"
                               HorizontalTextAlignment="Center" VerticalOptions="Center" />
                        <Button Grid.Column="2" Text="+" FontSize="24" FontAttributes="Bold" Padding="0"
                                TextColor="#333" BackgroundColor="Transparent"
                                Command="{Binding IncrementCommand}" />
                    </Grid>
                </Border>

                <!-- Кнопка підтвердження -->
                <Button Text="Оновити залишки" BackgroundColor="#7B2CBF" TextColor="White"
                        CornerRadius="12" HeightRequest="50" FontSize="16"
                        Command="{Binding ConfirmMrCommand}" />

            </VerticalStackLayout>
        </Frame>
    </Grid>
</ContentView>