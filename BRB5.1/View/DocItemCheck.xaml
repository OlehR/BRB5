<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:BRB6.ViewModel"
             xmlns:models="clr-namespace:BRB5.Model;assembly=BRB5.Model"
             x:DataType="vm:DocItemCheckVM"
             BackgroundColor="White"
             x:Class="BRB6.View.DocItemCheck">
    <NavigationPage.TitleView>
        <Grid BackgroundColor="White" >
            <Label Text="{Binding Title}" FontSize="20"  FontAttributes="Bold" TextColor="#1A1A1A" VerticalOptions="Center"  Margin="12,0,0,0" />
        </Grid>
    </NavigationPage.TitleView>
    <Grid RowDefinitions="Auto,*,Auto">

        <!-- ═══ TABLE ═══ -->
        <Grid Grid.Row="1" RowDefinitions="Auto,*">

            <!-- Заголовок таблиці -->
            <Grid
                Grid.Row="0"
                Padding="16,8"
                BackgroundColor="#F5F5F5"
                ColumnDefinitions="32,*,64,64"
                ColumnSpacing="8">

                <BoxView Grid.Column="0" Color="Transparent" />

                <Label
                    Grid.Column="1"
                    Text="Назва товару"
                    FontSize="13"
                    TextColor="#666666"
                    FontAttributes="Bold"
                    VerticalOptions="Center" />

                <Label
                    Grid.Column="2"
                    Text="Облік"
                    FontSize="13"
                    TextColor="#666666"
                    FontAttributes="Bold"
                    HorizontalOptions="Center"
                    VerticalOptions="Center" />

                <Label
                    Grid.Column="3"
                    Text="Викл-ка"
                    FontSize="13"
                    TextColor="#666666"
                    FontAttributes="Bold"
                    HorizontalOptions="Center"
                    VerticalOptions="Center" />
            </Grid>

            <!-- Список товарів -->
            <CollectionView
                Grid.Row="1"
                ItemsSource="{Binding Wares}"
                SelectionMode="None">

                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="models:DocWaresEx">
                        <Grid
                            Padding="16,12"
                            ColumnDefinitions="32,*,64,64"
                            ColumnSpacing="8">

                            <!-- Separator -->
                            <BoxView
                                Grid.ColumnSpan="4"
                                HeightRequest="1"
                                BackgroundColor="#EEEEEE"
                                VerticalOptions="End" />

                            <!-- Checkbox -->
                            <CheckBox
                                Grid.Column="0"
                                IsChecked="{Binding IsRecord}"
                                Color="#7B2FBE"
                                VerticalOptions="Center" />

                            <!-- Назва -->
                            <Label
                                Grid.Column="1"
                                Text="{Binding NameWares}"
                                FontSize="14"
                                TextColor="#1A1A1A"
                                LineBreakMode="WordWrap"
                                VerticalOptions="Center" />

                            <!-- Облік -->
                            <Label
                                Grid.Column="2"
                                Text="{Binding QuantityOrder}"
                                FontSize="14"
                                TextColor="#1A1A1A"
                                HorizontalOptions="Center"
                                VerticalOptions="Center" />

                            <!-- Викладка -->
                            <Label
                                Grid.Column="3"
                                Text="{Binding Quantity}"
                                FontSize="14"
                                TextColor="#1A1A1A"
                                HorizontalOptions="Center"
                                VerticalOptions="Center" />
                        </Grid>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

            <!-- Індикатор завантаження -->
            <ActivityIndicator
                Grid.Row="1"
                IsRunning="{Binding IsLoading}"
                IsVisible="{Binding IsLoading}"
                Color="#7B2FBE"
                VerticalOptions="Center"
                HorizontalOptions="Center" />
        </Grid>

        <!-- ═══ FOOTER BUTTON ═══ -->
        <Grid
            Grid.Row="2"
            Padding="16,12,16,32"
            BackgroundColor="White">

            <Button
                Text="Відвантажити корзину"
                Command="{Binding LoadCartCommand}"
                BackgroundColor="#7B2FBE"
                TextColor="White"
                FontSize="16"
                FontAttributes="Bold"
                CornerRadius="28"
                HeightRequest="56"
                HorizontalOptions="Fill" />
        </Grid>

    </Grid>
</ContentPage>