<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:BRB6.ViewModel"
             xmlns:models="clr-namespace:BRB5.Model;assembly=BRB5.Model"
             x:DataType="vm:DocItemCheckVM"
             xmlns:converters="clr-namespace:BRB6.View"
             BackgroundColor="White"
             x:Class="BRB6.View.DocItemCheck">
    <ContentPage.Resources>
        <converters:BoolToRowColorConverter x:Key="BoolToRowColorConverter" />
    </ContentPage.Resources>
    <NavigationPage.TitleView>
        <Grid BackgroundColor="White" >
            <Label Text="{Binding Title}" FontSize="20"  FontAttributes="Bold" TextColor="#1A1A1A" VerticalOptions="Center"  Margin="12,0,0,0" />
        </Grid>
    </NavigationPage.TitleView>
    <Grid RowDefinitions="*,Auto">

        <!-- ═══ TABLE ═══ -->
        <Grid RowDefinitions="Auto,*">

            <!-- Таблиця з рамкою -->
            <Border
                Grid.Row="0" Grid.RowSpan="2"
                Stroke="#D3D3D3" StrokeThickness="1"
                Margin="5,5,5,5">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="8" />
                </Border.StrokeShape>

                <Grid RowDefinitions="Auto,*">

                    <!-- Заголовок таблиці -->
                    <Grid
                        Grid.Row="0"
                        Padding="5,5" BackgroundColor="White"
                        ColumnDefinitions="32,*,56,64" ColumnSpacing="0">

                        <BoxView Grid.Column="0" Color="Transparent" />

                        <Label
                            Grid.Column="1"
                            Text="Назва товару" FontSize="13"
                            TextColor="Black" FontAttributes="Bold"
                            HorizontalOptions="Center" VerticalOptions="Center" />

                        <!-- Вертикальний розмежовувач -->
                        <BoxView
                            Grid.Column="2"
                            WidthRequest="1" BackgroundColor="#D3D3D3"
                            HorizontalOptions="Start" VerticalOptions="Fill" />

                        <Label
                            Grid.Column="2"
                            Text="Облік" FontSize="13"
                            TextColor="Black" FontAttributes="Bold"
                            HorizontalOptions="Center" VerticalOptions="Center" />

                        <!-- Вертикальний розмежовувач -->
                        <BoxView
                            Grid.Column="3"
                            WidthRequest="1" BackgroundColor="#D3D3D3"
                            HorizontalOptions="Start" VerticalOptions="Fill" />

                        <Label
                            Grid.Column="3"
                            Text="Викл-ка" FontSize="13"
                            TextColor="Black" FontAttributes="Bold"
                            HorizontalOptions="Center" VerticalOptions="Center" />
                    </Grid>

                    <!-- Горизонтальний розмежовувач після заголовку -->
                    <BoxView
                        Grid.Row="0"
                        HeightRequest="1" BackgroundColor="#D3D3D3"
                        VerticalOptions="End" />

                    <!-- Список товарів -->
                    <CollectionView
                        Grid.Row="1"
                        ItemsSource="{Binding Wares}" SelectionMode="Single">

                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="models:DocWaresEx">
                                <Grid>
                                    <!-- Фон рядка: сірий якщо відмічено, білий якщо ні -->
                                    <Grid
                                        Padding="5,5"
                                        ColumnDefinitions="32,*,56,64" ColumnSpacing="0"
                                        BackgroundColor="{Binding IsRecord, Converter={StaticResource BoolToRowColorConverter}}">

                                        <!-- Checkbox -->
                                        <CheckBox
                                            Grid.Column="0"
                                            IsChecked="{Binding IsRecord}" Color="#7B2FBE"
                                            VerticalOptions="Center" HorizontalOptions="Center" />

                                        <!-- Назва -->
                                        <Label
                                            Grid.Column="1"
                                            Text="{Binding NameWares}" FontSize="14"
                                            TextColor="#1A1A1A" LineBreakMode="WordWrap"
                                            HorizontalOptions="Center" VerticalOptions="Center" />

                                        <!-- Вертикальний розмежовувач -->
                                        <BoxView
                                            Grid.Column="2"
                                            WidthRequest="1" BackgroundColor="#D3D3D3"
                                            HorizontalOptions="Start" VerticalOptions="Fill" />

                                        <!-- Облік -->
                                        <Label
                                            Grid.Column="2"
                                            Text="{Binding QuantityOrder}" FontSize="14"
                                            TextColor="#1A1A1A" HorizontalOptions="Center"
                                            VerticalOptions="Center" />

                                        <!-- Вертикальний розмежовувач -->
                                        <BoxView
                                            Grid.Column="3"
                                            WidthRequest="1" BackgroundColor="#D3D3D3"
                                            HorizontalOptions="Start" VerticalOptions="Fill" />

                                        <!-- Викладка -->
                                        <Label
                                            Grid.Column="3"
                                            Text="{Binding Quantity}" FontSize="14"
                                            TextColor="#1A1A1A" HorizontalOptions="Center"
                                            VerticalOptions="Center" />
                                    </Grid>

                                    <!-- Горизонтальний розмежовувач -->
                                    <BoxView
                                        HeightRequest="1" BackgroundColor="#D3D3D3"
                                        VerticalOptions="End" />
                                </Grid>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>

                        <!-- Стиль сфокусованого елементу -->
                        <CollectionView.ItemsLayout>
                            <LinearItemsLayout Orientation="Vertical" ItemSpacing="0" />
                        </CollectionView.ItemsLayout>

                        <VisualStateManager.VisualStateGroups>
                            <VisualStateGroup Name="CommonStates">
                                <VisualState Name="Normal">
                                    <VisualState.Setters>
                                        <Setter Property="BackgroundColor" Value="Transparent" />
                                    </VisualState.Setters>
                                </VisualState>
                                <VisualState Name="Selected">
                                    <VisualState.Setters>
                                        <Setter Property="BackgroundColor" Value="#EDE7F6" />
                                    </VisualState.Setters>
                                </VisualState>
                            </VisualStateGroup>
                        </VisualStateManager.VisualStateGroups>
                    </CollectionView>

                    <!-- Індикатор завантаження -->
                    <ActivityIndicator
                        Grid.Row="1"
                        IsRunning="{Binding IsLoading}" IsVisible="{Binding IsLoading}"
                        Color="#7B2FBE" VerticalOptions="Center"
                        HorizontalOptions="Center" />

                </Grid>
            </Border>
        </Grid>


        <!-- ═══ FOOTER BUTTON ═══ -->
        <Grid  Grid.Row="2" BackgroundColor="White">

            <Button
                Text="Відвантажити корзину"
                Command="{Binding LoadCartCommand}"
                BackgroundColor="#7B2FBE"
                TextColor="White"
                FontSize="16"
                FontAttributes="Bold"
                CornerRadius="28"
                HeightRequest="56"
                HorizontalOptions="Fill" />
        </Grid>

    </Grid>
</ContentPage>