<?xml version="1.0" encoding="utf-8"?>

<controls:BaseContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
                          xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
                          xmlns:controls="clr-namespace:BRB6.View"
                          xmlns:templates="clr-namespace:BRB6.Template"
                          xmlns:scanner="clr-namespace:BarcodeScanning;assembly=BarcodeScanning.Native.Maui"
                          xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"                          
                          xmlns:ffimageloading="clr-namespace:FFImageLoading.Maui;assembly=FFImageLoading.Maui"
                          x:Class="BRB6.PriceCheckSim23">
    <ContentPage.Content>
        <Grid>
        <VerticalStackLayout>
            <Grid x:Name="GridZxing" IsVisible="{Binding IsVisScan}" HeightRequest="150"/>

            <VerticalStackLayout Margin="12" Spacing="5">

                <Grid>
                    <Border StrokeShape="RoundRectangle 12" Stroke="#E0E0E0" BackgroundColor="White" Padding="10,0">
                        <Grid ColumnDefinitions="Auto, *, Auto">
                            <Image Grid.Column="0" Source="barcode_scanning.png" HeightRequest="24" WidthRequest="24" VerticalOptions="Center" />

                            <controls:CustomEntry Grid.Column="1" x:Name="BarCodeInput" Keyboard="Numeric" Text="{Binding BarCodeInput, Mode=TwoWay}" VerticalOptions="Center" Margin="8,0">
                                <controls:CustomEntry.Behaviors>
                                    <toolkit:EventToCommandBehavior EventName="Completed" Command="{Binding BarCodeHandInputCommand}" />
                                </controls:CustomEntry.Behaviors>
                            </controls:CustomEntry>

                            <Label Grid.Column="2" Text="{Binding ExtraBarCodesCount, StringFormat='+{0}'}" FontSize="16" TextColor="#7B2CBF" FontAttributes="Bold" VerticalOptions="Center" IsVisible="{Binding HasExtraBarCodes}">
                                <Label.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding ShowAllBarCodesCommand}" />
                                </Label.GestureRecognizers>
                            </Label>
                        </Grid>
                    </Border>

                    <Border ZIndex="10" IsVisible="{Binding IsBarCodesDropdownVisible}" StrokeShape="RoundRectangle 12" Stroke="#E0E0E0" BackgroundColor="White" Padding="10,5" VerticalOptions="Start">
                        <Grid>
                            <VerticalStackLayout Spacing="8" BindableLayout.ItemsSource="{Binding AllBarCodes}">
                                <BindableLayout.ItemTemplate>
                                    <DataTemplate>
                                        <Grid ColumnDefinitions="Auto, *">
                                            <Image Grid.Column="0" Source="barcode_scanning.png" HeightRequest="20" WidthRequest="20" VerticalOptions="Center" />
                                            <Label Grid.Column="1" Text="{Binding .}" FontSize="18" Margin="8,0" VerticalOptions="Center" />
                                        </Grid>
                                    </DataTemplate>
                                </BindableLayout.ItemTemplate>
                            </VerticalStackLayout>

                            <Label Text="×" FontSize="20" HorizontalOptions="End" VerticalOptions="Start" TextColor="Gray" ZIndex="1">
                                <Label.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding CloseBarCodesCommand}" />
                                </Label.GestureRecognizers>
                            </Label>
                        </Grid>
                    </Border>
                </Grid>

                <BoxView HeightRequest="1" Color="#EEEEEE" />

                <Grid ColumnDefinitions="80, *" ColumnSpacing="15">
                    <ffimageloading:CachedImage x:Name="WareImage" Grid.Column="0" ErrorPlaceholder="photo.png" Source="{Binding UriPicture}" 
                                                WidthRequest="80" MaximumHeightRequest="100" Aspect="AspectFit" VerticalOptions="Start" />
                    <Label Grid.Column="1" Text="{Binding WP.Name}" FontSize="22" FontAttributes="Bold" LineBreakMode="TailTruncation" MaxLines="4" VerticalOptions="Center" />
                </Grid>

                <Frame BackgroundColor="{Binding BackgroundColorPrice}" CornerRadius="20" HasShadow="False" Padding="10,5" BorderColor="#E0E0E0">
                    <Grid ColumnDefinitions="*, Auto" RowDefinitions="Auto, Auto">

                        <Label Grid.Row="0" Grid.Column="0" Text="Ціна:" FontSize="16" TextColor="Gray" />
                        <Label Grid.Row="1" Grid.Column="0" Text="{Binding WP.Price}" FontSize="48" 
                               FontAttributes="Bold" TextColor="{Binding TextColorPrice}" VerticalOptions="Start" />

                        <VerticalStackLayout IsVisible="{Binding IsVisPromotion}" Grid.Row="0" Grid.Column="1" Grid.RowSpan="2" Spacing="5" VerticalOptions="Center" HorizontalOptions="End">
                            <Button Text="{Binding WP.PromotionName}"  BackgroundColor="#FF7A00" TextColor="White"
                                    CornerRadius="8" HeightRequest="34" Padding="10,0" FontSize="14" />
                            <HorizontalStackLayout>
                                <Label Text="Діє до: " FontSize="12" HorizontalOptions="End"  />
                                <Label Text="{Binding WP.PromotionEnd, StringFormat='{}{0:dd.MM.yy}'}"  FontAttributes="Bold" FontSize="12" HorizontalOptions="End" />
                            </HorizontalStackLayout>
                        </VerticalStackLayout>

                    </Grid>
                </Frame>

                <VerticalStackLayout Spacing="5">
                    <Grid ColumnDefinitions="*, Auto">
                        <Label Text="Код товару:" TextColor="Black" FontSize="16" />
                        <Label Grid.Column="1" Text="{Binding WP.Article}" FontAttributes="Bold" FontSize="16" />
                    </Grid>
                    <BoxView HeightRequest="1" Color="#EEEEEE" />
                    <Grid ColumnDefinitions="*, Auto, Auto">
                        <Label Text="Термін придатності:" TextColor="Black" FontSize="16" />
                        <Label Grid.Column="1" Text="{Binding WP.ExpirationDay}" FontAttributes="Bold" FontSize="16" />
                        <Label Grid.Column="2" Text=" дні" FontAttributes="Bold" FontSize="16" />
                    </Grid>
                    <BoxView HeightRequest="1" Color="#EEEEEE" />

                    <Grid ColumnDefinitions="*, Auto">
                        <Label Text="Залишок (шт):" TextColor="Black" FontSize="16" />
                        <Label Grid.Column="1" Text="{Binding WP.Rest}" FontAttributes="Bold" FontSize="16" />
                    </Grid>

                        <Button Text="Провести МР" BackgroundColor="#E9EAEF" TextColor="Black" Command="{Binding OpenMrDialogCommand}"
                                IsEnabled="{Binding HasWare}" CornerRadius="20" Padding="0" HeightRequest="40" FontSize="20" FontAttributes="Bold" />

                    <BoxView HeightRequest="1" Color="#EEEEEE" Margin="0,-5" />
                    
                    <Grid ColumnDefinitions="*, Auto">
                        <Label Text="Місць викладки:" TextColor="Black" FontSize="16" />
                        <Label Grid.Column="1" Text="{Binding WP.Shelves}" FontAttributes="Bold" FontSize="16" />
                    </Grid>
                </VerticalStackLayout>

                <Grid ColumnDefinitions="2*,*,2*,3*,2*,2*" HeightRequest="52" ColumnSpacing="0" Margin="0">

                    <Button Grid.Column="0" FontSize="30"  FontAttributes="Bold" Text="C" TextColor="White" BackgroundColor="#7B2CBF" 
                            Command="{Binding ClearCommand}" Padding="0" Margin="2" CornerRadius="15" />

                    <Button Grid.Column="2" FontSize="40" FontAttributes="Bold" Text="—" TextColor="#7B2CBF" BackgroundColor="White" 
                            Margin="2"  Padding="0" Command="{Binding ModifyValueCommand}" CommandParameter="-1" CornerRadius="15" />

                    <Border Grid.Column="3" StrokeShape="RoundRectangle 12" Stroke="#E0E0E0" BackgroundColor="White" >
                        <controls:CustomEntry Text="{Binding NumberOfReplenishment, Mode=TwoWay}" Keyboard="Numeric"  
                                              HorizontalOptions="Center" VerticalOptions="Center" FontSize="28" FontAttributes="Bold" >
                            <controls:CustomEntry.Behaviors>
                                <toolkit:EventToCommandBehavior EventName="Unfocused" Command="{Binding UpdateReplenishmentCommand}" />
                                <toolkit:EventToCommandBehavior EventName="Completed" Command="{Binding UpdateReplenishmentCommand}" />
                            </controls:CustomEntry.Behaviors>
                        </controls:CustomEntry>
                    </Border>

                    <Button Grid.Column="4" FontSize="40" FontAttributes="Bold" Text="+" TextColor="#7B2CBF" BackgroundColor="White" 
                            HorizontalOptions="Center" VerticalOptions="Center" 
                            Margin="2" Padding="0" Command="{Binding ModifyValueCommand}" CommandParameter="1" CornerRadius="15" />

                    <Button Grid.Column="5" FontSize="30" FontAttributes="Bold" Text="{Binding QuantityToAddText}" Margin="2" Padding="0" 
                            TextColor="#7B2CBF" BackgroundColor="White" BorderWidth="1" BorderColor="#E0E0E0"
                            Command="{Binding ModifyValueCommand}" CommandParameter="{Binding QuantityToAdd}"   CornerRadius="15" />
                </Grid>

            </VerticalStackLayout>
        </VerticalStackLayout>
            <templates:MRDialog x:Name="MRDialogView" BindingContext="{Binding}"  ZIndex="10" DialogTitle="Вкажіть актуальну кількість товару" />
        </Grid>
    </ContentPage.Content>
</controls:BaseContentPage>